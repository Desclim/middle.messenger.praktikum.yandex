{
  "name": "middle.messenger.praktikum.yandex",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "start": "npm run typecheck && vite build && vite preview",
    "lint:ts": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "lint:styles:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "lint": "npm run lint:ts && npm run lint:styles",
    "test": "mocha",
    "check": "npm run typecheck && npm run lint && npm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/jsdom": "^28.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "chai": "^6.2.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.5",
    "sass": "^1.97.3",
    "stylelint": "^17.5.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "handlebars": "^4.7.8"
  },
