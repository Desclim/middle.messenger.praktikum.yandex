<div class="context-menu" ref={{ref}}>
  <button class="context-menu__trigger" type="button">
    {{text}}
  </button>

  <div class="context-menu__dropdown {{#unless isOpen}}context-menu__dropdown_hidden{{/unless}}">
    {{#each items}}
      <button
        class="context-menu__item"
        type="button"
        data-action="{{action}}"
      >
        <img class="context-menu__icon" alt="contextImg" src="{{icon}}" />
        {{label}}
      </button>
    {{/each}}
  </div>
</div>
