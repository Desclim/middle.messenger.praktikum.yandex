<a
        class="chat-item {{#if active}}chat-item_active{{/if}}"
        data-chat-id="{{id}}"
        href="#"
>
    <div class="chat-item__avatar">
        {{#if avatar}}
            <img src="{{avatar}}" alt="{{title}}">
        {{/if}}
    </div>

    <div class="chat-item__content">
        <div class="chat-item__header">
            <span class="chat-item__title">
                {{title}}
            </span>

            <span class="chat-item__time">
                {{time}}
            </span>
        </div>

        <div class="chat-item__footer">
            <span class="chat-item__message">
                {{message}}
            </span>

            {{#if unread}}
                <div class="chat-item__counterContainer">
                    <div class="counter">
                        <span class="counter__content">
                            {{unread}}
                        </span>
                    </div>
                </div>
            {{/if}}
        </div>
    </div>
</a>
