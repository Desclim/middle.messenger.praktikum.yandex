<form class="search" data-search="{{name}}">
  <label class="search__control" for="{{id}}">
    <input
      class="search__field"
      id="{{id}}"
      ref="{{ref}}"
      type="search"
      name="{{name}}"
      value="{{value}}"
      autocomplete="off"
      aria-label="{{placeholder}}"
    />

    <span class="search__placeholder" aria-hidden="true">
      <img src="/icons/search.svg" class="search__icon" alt="" />
      <span class="search__text">{{placeholder}}</span>
    </span>
  </label>
</form>
