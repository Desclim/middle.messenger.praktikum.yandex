<div class="profile-avatar">
  <div class="profile-avatar__avatar">
    <img alt="">
    <input
      class="profile-avatar__input"
      type="file"
      name="avatar"
      accept="image/*"
      ref={{ref}}
    >
  </div>

  {{#if showDisplayName}}
    <h2 class="profile-avatar__name">
      {{displayName}}
    </h2>
  {{/if}}
</div>
