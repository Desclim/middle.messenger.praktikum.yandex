<main class="edit-password">
  <div class="edit-password__sidebar">
    {{{ ProfileBackButton href="/profile" ref="profileBackButton" }}}
  </div>

  <section class="edit-password__content">
    <header class="edit-password__header">
      {{{ ProfileAvatar
        displayName=displayName
        showDisplayName=false
        ref="profileAvatar"
      }}}
    </header>

    <form class="edit-password__form" id="edit-password-form" autocomplete="off">
      {{{ Input
        id="old_password"
        name="old_password"
        type="password"
        label="Старый пароль"
        value=""
        autocomplete="off"
        ref="old_password"
        validator=newPasswordValidator
      }}}

      {{{ Input
        id="new_password"
        name="new_password"
        type="password"
        label="Новый пароль"
        value=""
        autocomplete="new-password"
        ref="new_password"
        validator=newPasswordValidator
      }}}

      {{{ Input
        id="new_password_repeat"
        name="new_password_repeat"
        type="password"
        label="Повторите новый пароль"
        value=""
        autocomplete="new-password"
        ref="new_password_repeat"
        validator=newPasswordRepeatValidator
      }}}
    </form>

    <footer class="edit-password__footer">
      {{{ Button
        name="edit-password-form-submit"
        type="submit"
        label="Сохранить"
        form="edit-password-form"
      }}}
    </footer>
  </section>
</main>
