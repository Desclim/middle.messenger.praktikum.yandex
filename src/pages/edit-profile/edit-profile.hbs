<main class="edit-profile">
  <div class="edit-profile__sidebar">
    {{{ ProfileBackButton href="/profile" ref="profileBackButton" }}}
  </div>

  <section class="edit-profile__content">
    <header class="edit-profile__header">
      {{{ ProfileAvatar
        displayName=displayName
        showDisplayName=false
        ref="profileAvatar"
      }}}
    </header>

    <form class="edit-profile__form" id="edit-profile-form">
      {{{ Input
        id="email"
        name="email"
        type="text"
        label="Почта"
        value=email
        autocomplete="email"
        ref="email"
        validator=emailValidator
      }}}

      {{{ Input
        id="login"
        name="login"
        type="text"
        label="Логин"
        value=login
        autocomplete="username"
        ref="login"
        validator=loginValidator
      }}}

      {{{ Input
        id="first_name"
        name="first_name"
        type="text"
        label="Имя"
        value=firstName
        autocomplete="given-name"
        ref="first_name"
        validator=nameValidator
      }}}

      {{{ Input
        id="second_name"
        name="second_name"
        type="text"
        label="Фамилия"
        value=secondName
        autocomplete="family-name"
        ref="second_name"
        validator=nameValidator
      }}}

      {{{ Input
        id="phone"
        name="phone"
        type="tel"
        label="Телефон"
        value=phone
        autocomplete="tel"
        ref="phone"
        validator=phoneValidator
        mask="phone"
      }}}
    </form>

    <footer class="edit-profile__footer">
      {{{ Button
        name="edit-profile-form-submit"
        type="submit"
        label="Сохранить"
        form="edit-profile-form"
      }}}
    </footer>
  </section>
</main>
